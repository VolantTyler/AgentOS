# Copy to .env and fill in (never commit .env)
# Cursor API key for @cursor/sdk — see https://cursor.com/dashboard/cloud-agents
CURSOR_API_KEY=

# Optional lead tracker Google Sheets config
LEAD_TRACKER_SPREADSHEET_ID=
LEAD_TRACKER_SHEET_RANGE=Recent Contacts!A:K

# Optional job-fit tracker Google Sheets config
JOB_FIT_TRACKER_SPREADSHEET_ID=
# Quote the whole value when the tab name contains spaces (match your tab exactly)
JOB_FIT_TRACKER_SHEET_RANGE='Job Fit Agent Reviews!A:R'

# Optional gws auth override — only set if credentials.json exists (from `gws auth export --unmasked`)
# GOOGLE_WORKSPACE_CLI_CREDENTIALS_FILE=/absolute/path/to/credentials.json
